# Coffee bag corpus — JPEG label photos and the metadata index live
# next to each other at D:\Cloud\Proton\My files\Coffee bags on the
# author's workstation (and the equivalent on CI runners that have the
# corpus mounted). They are NEVER committed to git — the photos contain
# label artwork that may be copyrighted, and the corpus changes
# independently of the app's release cadence. The test harness reads
# them through the MINDLAYER_COFFEE_BAG_CORPUS environment variable
# (CoffeeBagCorpusExtractionTest.kt) and skips cleanly when that env
# var is unset, so CI without the corpus mounted just doesn't run those
# tests rather than failing.
/coffee-bags-corpus/
/app/coffee-bags-corpus/

# Python bytecode cache
__pycache__/

# Asset-generation intermediates and local validation artifacts — large
# binary work products from icon/spritesheet generation that are not app
# resources and should not bloat git history. The shipped assets live in
# app/src/main/res/drawable-nodpi.
/docs/assets/vessel-icons/
/tools/bloom-validation/

# Synthetic coffee-bag image corpus (large test images, mirrors the
# coffee-bags-corpus policy above — kept local, not version-controlled).
/testdata/synthetic-coffee-bag-corpus/

