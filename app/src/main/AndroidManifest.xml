<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--
        Expedited WorkManager runs the on-device AI bag-label extraction so it
        survives app backgrounding and process death. On API 26-30 an expedited
        WorkRequest falls back to a short foreground service, which requires this
        permission. On API 31+ it uses the expedited job quota (no service).
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!--
        Package visibility (Android 11+) for the Mindlayer on-device AI service.
        The SDK binds to this service across processes; without an explicit
        <queries> entry, bindService() silently returns false ("service not
        found") because the target package is filtered out. Visibility used to
        come implicitly from the com.adsamcik.mindlayer.permission.BIND_ML_SERVICE
        uses-permission, but Mindlayer no longer defines that permission, so the
        app must declare the service packages directly. Both the release and
        debug service variants are listed because the SDK binds the variant that
        matches the build type.
    -->
    <queries>
        <package android:name="com.adsamcik.mindlayer.service" />
        <package android:name="com.adsamcik.mindlayer.service.debug" />
    </queries>

    <application
        android:name=".StarlitCoffeeApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="${appLabel}"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.StarlitCoffee"
        tools:replace="android:dataExtractionRules"
        tools:targetApi="33">

        <uses-native-library android:name="libvndksupport.so" android:required="false"/>
        <uses-native-library android:name="libOpenCL.so" android:required="false"/>

        <!--
            screenOrientation="portrait" is honoured on phones but is ignored on
            large screens (sw>=600dp) for apps targeting Android 17 (SDK 37) or higher.
            configChanges lets us absorb the forced tablet rotation without recreating
            the activity; Compose picks up the new config via LocalConfiguration.

            tools:ignore — the live brew/scan UIs are designed for portrait holding
            the phone on a kitchen scale; a landscape layout isn't a meaningful
            second design today. Suppress lint's Chrome-OS / Android-16 nags about
            the locked orientation explicitly (DiscouragedApi, LockedOrientationActivity).
        -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode|density|fontScale"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.StarlitCoffee"
            tools:ignore="DiscouragedApi,LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
            Rating reminder pipeline. Both receivers are internal — the alarm
            receiver is driven by our own AlarmManager schedule and the action
            receiver only handles taps inside notifications we posted ourselves,
            so neither needs `exported=true`.
        -->
        <receiver
            android:name=".notification.RatingReminderReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".notification.RatingActionReceiver"
            android:enabled="true"
            android:exported="false" />
    </application>

</manifest>
