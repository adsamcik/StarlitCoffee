    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="prep_tip_label">Preparazione</string>
    <string name="label_recipe_heading">Ricetta</string>
    <string name="label_set_grinder_to">Imposta il macinacaffè su</string>
    <string name="label_temp_short">Temp</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Bagna il filtro di carta nella base (valvola aperta) e fai scolare. Monta il cilindro, aggiungi il caffè macinato, livella il letto, posiziona il tappo di dispersione. Tara la bilancia.</string>
    <string name="prep_tip_pulsar_19k">Sciacqua il filtro metallico 19K per farlo aderire e preriscaldare il cilindro. Monta il cilindro, aggiungi il caffè macinato, livella il letto, posiziona il tappo di dispersione. Tara la bilancia.</string>
    <string name="prep_tip_pulsar_40k">Sciacqua il filtro metallico 40K per preriscaldare il cilindro. Monta il cilindro, aggiungi il caffè macinato, livella il letto, posiziona il tappo di dispersione. Tara la bilancia.</string>
    <string name="prep_tip_pour_over_paper">Inserisci il filtro di carta e sciacqualo con acqua calda per preriscaldare e rimuovere il gusto di carta. Aggiungi il caffè macinato e tara la bilancia.</string>
    <string name="prep_tip_french_press">Preriscalda la pressa, poi svuotala. Aggiungi il caffè macinato, metti sulla bilancia e tara prima di aggiungere acqua.</string>
    <string name="prep_tip_aeropress">Inserisci un filtro sciacquato nel tappo. Aggiungi il caffè macinato, appoggia l\'AeroPress su una tazza o server stabile e tara la bilancia.</string>
    <string name="prep_tip_espresso">Asciuga il portafiltro. Dosa, distribuisci e pressa in piano prima di agganciare.</string>
    <string name="prep_tip_moka">Riempi la camera inferiore fino alla valvola. Riempi il filtro con il caffè macinato, livella — non pressare. Assembla con attenzione.</string>
    <string name="prep_tip_cold_brew">Aggiungi il caffè macinato al recipiente, tara la bilancia, poi aggiungi acqua fredda o a temperatura ambiente e copri.</string>

