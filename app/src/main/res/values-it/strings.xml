    <string name="label_bloom_sprite_coffee_flower">Fiore del caffè</string>
    <string name="desc_bloom_sprite_coffee_flower">Classico fiore bianco del caffè che si apre dal chicco.</string>
    <string name="label_bloom_sprite_coffee_starlit">Caffè stellato</string>
    <string name="desc_bloom_sprite_coffee_starlit">Petali di vapore color crema e oro con piccoli riflessi stellati.</string>
    <string name="label_bloom_sprite_coffee_latte">Bloom latte</string>
    <string name="desc_bloom_sprite_coffee_latte">Morbida rosetta di latte art in toni caldi di schiuma di latte.</string>
    <string name="label_bloom_sprite_coffee_plant">Pianta di caffè</string>
    <string name="desc_bloom_sprite_coffee_plant">Giovane piantina di caffè verde brillante con foglie appaiate.</string>
    <string name="label_bloom_sprite_cherry_tomato">Pomodorino</string>
    <string name="desc_bloom_sprite_cherry_tomato">Da un chicco di caffè germoglia una vite di pomodoro mentre maturano frutti rossi.</string>
    <string name="label_bloom_sprite_strawberry">Fragola</string>
    <string name="desc_bloom_sprite_strawberry">Da un chicco di caffè germoglia una pianta di fragola con fiori e bacche rosse.</string>
    <string name="label_bloom_sprite_raspberry">Lampone</string>
    <string name="desc_bloom_sprite_raspberry">Un chicco di caffè fa crescere rovi con fiori chiari e grappoli di lamponi rossi.</string>
    <string name="label_bloom_sprite_blueberry">Mirtillo</string>
    <string name="desc_bloom_sprite_blueberry">Un chicco di caffè fa crescere un rametto di mirtillo con fiori a campana e frutti blu.</string>
    <string name="label_bloom_sprite_blackberry">Mora</string>
    <string name="desc_bloom_sprite_blackberry">Un chicco di caffè fa crescere rovi spinosi con grappoli di more scure.</string>
    <string name="label_bloom_sprite_coffee_brew">Caffè in estrazione</string>
    <string name="desc_bloom_sprite_coffee_brew">Bagliore ambrato di caffè con spirali di vapore crema.</string>
    <string name="label_bloom_sprite_cursed_relic">Reliquia maledetta</string>
    <string name="desc_bloom_sprite_cursed_relic">Un chicco crepato libera magia dorata e vapore nero in un medaglione lupesco.</string>
    <string name="label_bloom_sprite_rose">Rosa</string>
    <string name="desc_bloom_sprite_rose">Rosa rossa compatta che si schiude sopra il chicco.</string>
    <string name="label_bloom_sprite_lotus">Loto</string>
    <string name="desc_bloom_sprite_lotus">Fiore di loto color crema con petali concavi sovrapposti.</string>
    <string name="label_bloom_sprite_sunflower">Girasole</string>
    <string name="desc_bloom_sprite_sunflower">Girasole luminoso con petali dorati e centro scuro.</string>
    <string name="label_bloom_sprite_orchid">Orchidea</string>
    <string name="desc_bloom_sprite_orchid">Delicata orchidea bianca con lobi arrotondati.</string>
    <string name="label_bloom_sprite_jasmine">Gelsomino</string>
    <string name="desc_bloom_sprite_jasmine">Morbido fiore bianco di gelsomino con delicata forma a girandola.</string>
    <string name="label_bloom_sprite_bleeding_heart">Dicentra</string>
    <string name="desc_bloom_sprite_bleeding_heart">Steli arcuati con fiori rosa a forma di cuore e punte bianche a goccia emergono dal chicco.</string>
    <string name="label_bloom_sprite_passionflower">Passiflora</string>
    <string name="desc_bloom_sprite_passionflower">Viti arricciate si aprono in una passiflora ornata viola e bianca sopra il chicco.</string>
    <string name="label_bloom_sprite_bee_orchid">Ofride fior di ape</string>
    <string name="desc_bloom_sprite_bee_orchid">Petali rosa di orchidea rivelano labelli scuri a forma di ape su steli sottili.</string>
    <string name="label_bloom_sprite_jade_vine">Vite di giada</string>
    <string name="desc_bloom_sprite_jade_vine">Una vite rampicante fa pendere dal chicco grappoli turchesi di fiori di giada.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Strelitzia</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Petali arancioni e blu profondo di Strelitzia si schiudono da foglie verdi erette.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Papavero blu himalayano</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Un bocciolo pendulo si apre in un papavero azzurro cielo con stami dorati.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Un fiore parassita rosso maculato si gonfia in un enorme fiore a cinque lobi.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Cosmos cioccolato</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">Foglie piumose sollevano dal chicco fiori di cosmos vellutati color borgogna scuro.</string>
    <string name="label_bloom_sprite_flame_lily">Giglio fiamma</string>
    <string name="desc_bloom_sprite_flame_lily">Petali di giglio color fiamma si arricciano su steli verdi con viticci.</string>
    <string name="label_bloom_sprite_queen_of_the_night">Regina della notte</string>
    <string name="desc_bloom_sprite_queen_of_the_night">Uno stelo di cactus si apre in un drammatico fiore notturno bianco a strati.</string>
    <string name="label_bloom_sprite_snowdrop">Bucaneve</string>
    <string name="desc_bloom_sprite_snowdrop">Delicate campanelle bianche di bucaneve emergono dal chicco crepato.</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
    <string name="desc_bloom_sprite_myosotis_sylvatica">Minuscoli fiori blu di non ti scordar di me con centri gialli si schiudono dal chicco.</string>
    <string name="label_bloom_sprite_fantasy_citadel">Cittadella fantasy</string>
    <string name="desc_bloom_sprite_fantasy_citadel">Un chicco crepato si apre in una minuscola cittadella di pietra con finestre calde.</string>
    <string name="label_bloom_sprite_cyber_city_vines">Rampicanti cyber city</string>
    <string name="desc_bloom_sprite_cyber_city_vines">Viti circuitali al neon crescono in una compatta cyber city in miniatura.</string>
    <string name="label_bloom_sprite_pixel_micro_world">Micro-mondo pixel</string>
    <string name="desc_bloom_sprite_pixel_micro_world">Il chicco si pixelizza in un micro-mondo retro di blocchi e terreno.</string>
    <string name="label_bloom_sprite_tabletop_adventure_map">Mappa di avventura da tavolo</string>
    <string name="desc_bloom_sprite_tabletop_adventure_map">Un chicco rotolante si dispiega in una piccola mappa di avventura su pergamena e un dado-gemma vuoto.</string>
    <string name="label_bloom_sprite_alchemy_astrolabe">Astrolabio alchemico</string>
    <string name="desc_bloom_sprite_alchemy_astrolabe">Anelli di ottone e fiale di vetro orbitanti si aprono dal chicco di caffè.</string>
    <string name="label_bloom_sprite_espresso_robot">Robot espresso</string>
    <string name="desc_bloom_sprite_espresso_robot">Il chicco si dispiega in un piccolo robot di ottone alimentato a espresso.</string>
    <string name="label_bloom_sprite_space_habitat_ring">Anello habitat spaziale</string>
    <string name="desc_bloom_sprite_space_habitat_ring">Pezzi curvi di guscio si separano in un anello habitat rotante in miniatura.</string>
    <string name="label_bloom_sprite_nerd_library_nook">Angolo biblioteca nerd</string>
    <string name="desc_bloom_sprite_nerd_library_nook">Un angolo biblioteca pop-up si apre dal chicco con scaffali, lampada e mug.</string>
    <string name="label_bloom_sprite_arcade_platformer_level">Livello platform arcade</string>
    <string name="desc_bloom_sprite_arcade_platformer_level">Dal chicco spunta un minuscolo livello platform originale con blocchi, gemme e bandiera.</string>
    <string name="label_bloom_sprite_clockwork_dragonfly">Libellula meccanica</string>
    <string name="desc_bloom_sprite_clockwork_dragonfly">Un guscio di caffè si schiude in una libellula meccanica di ottone.</string>
    <string name="label_bloom_sprite_observatory_dome">Cupola osservatorio</string>
    <string name="desc_bloom_sprite_observatory_dome">Il chicco si apre come una minuscola cupola di osservatorio con telescopio in ottone.</string>
    <string name="label_bloom_sprite_cyber_alchemy_engine">Motore cyber-alchemico</string>
    <string name="desc_bloom_sprite_cyber_alchemy_engine">Anelli di ottone, circuiti e un nucleo ambrato formano un compatto motore cyber-alchemico.</string>
    <string name="label_bloom_sprite_tabletop_space_colony">Colonia spaziale da tavolo</string>
    <string name="desc_bloom_sprite_tabletop_space_colony">Una piccola colonia spaziale da gioco da tavolo si solleva con cupole e lune-dado vuote.</string>
    <string name="label_bloom_sprite_observatory_library">Biblioteca osservatorio</string>
    <string name="desc_bloom_sprite_observatory_library">Una biblioteca osservatorio accogliente si apre con scaffali, telescopio e costellazioni di vapore.</string>

