    <string name="label_bloom_sprite_coffee_flower">Kwiat kawowca</string>
    <string name="desc_bloom_sprite_coffee_flower">Klasyczny biały kwiat kawowca rozwijający się z ziarna.</string>
    <string name="label_bloom_sprite_coffee_starlit">Starlit coffee</string>
    <string name="desc_bloom_sprite_coffee_starlit">Kremowo-złote płatki pary z drobnymi świetlistymi akcentami.</string>
    <string name="label_bloom_sprite_coffee_latte">Latte bloom</string>
    <string name="desc_bloom_sprite_coffee_latte">Delikatna rozeta latte art w ciepłych tonach mlecznej pianki.</string>
    <string name="label_bloom_sprite_coffee_plant">Kawowiec</string>
    <string name="desc_bloom_sprite_coffee_plant">Świeża zielona sadzonka kawowca z parzystymi liśćmi.</string>
    <string name="label_bloom_sprite_cherry_tomato">Pomidor koktajlowy</string>
    <string name="desc_bloom_sprite_cherry_tomato">Ziarno kawy kiełkuje w pęd pomidora, na którym dojrzewają czerwone owoce.</string>
    <string name="label_bloom_sprite_strawberry">Truskawka</string>
    <string name="desc_bloom_sprite_strawberry">Ziarno kawy kiełkuje w krzaczek truskawki z kwiatami i czerwonymi owocami.</string>
    <string name="label_bloom_sprite_raspberry">Malina</string>
    <string name="desc_bloom_sprite_raspberry">Ziarno kawy wypuszcza pędy z jasnymi kwiatami i gronami czerwonych malin.</string>
    <string name="label_bloom_sprite_blueberry">Borówka</string>
    <string name="desc_bloom_sprite_blueberry">Ziarno kawy wypuszcza gałązkę borówki z dzwonkowatymi kwiatami i niebieskimi owocami.</string>
    <string name="label_bloom_sprite_blackberry">Jeżyna</string>
    <string name="desc_bloom_sprite_blackberry">Ziarno kawy wypuszcza kolczaste pędy z gronami ciemnych jeżyn.</string>
    <string name="label_bloom_sprite_coffee_brew">Napar kawowy</string>
    <string name="desc_bloom_sprite_coffee_brew">Bursztynowa poświata kawy z kremowymi zawijasami pary.</string>
    <string name="label_bloom_sprite_cursed_relic">Przeklęty relikt</string>
    <string name="desc_bloom_sprite_cursed_relic">Pęknięte ziarno uwalnia złotą magię i czarny opar do medalionu podobnego do wilka.</string>
    <string name="label_bloom_sprite_rose">Róża</string>
    <string name="desc_bloom_sprite_rose">Zwarta czerwona róża rozwijająca się nad ziarnem.</string>
    <string name="label_bloom_sprite_lotus">Lotos</string>
    <string name="desc_bloom_sprite_lotus">Kremowy kwiat lotosu z warstwowymi, kielichowatymi płatkami.</string>
    <string name="label_bloom_sprite_sunflower">Słonecznik</string>
    <string name="desc_bloom_sprite_sunflower">Jasny słonecznik ze złotymi płatkami i ciemnym środkiem.</string>
    <string name="label_bloom_sprite_orchid">Orchidea</string>
    <string name="desc_bloom_sprite_orchid">Delikatna biała orchidea z zaokrąglonymi płatkami.</string>
    <string name="label_bloom_sprite_jasmine">Jaśmin</string>
    <string name="desc_bloom_sprite_jasmine">Miękki biały kwiat jaśminu o subtelnym kształcie wiatraczka.</string>
    <string name="label_bloom_sprite_bleeding_heart">Serduszka okazałe</string>
    <string name="desc_bloom_sprite_bleeding_heart">Z ziarna wyrastają łukowate łodygi z różowymi kwiatami w kształcie serca i białymi końcówkami.</string>
    <string name="label_bloom_sprite_passionflower">Męczennica</string>
    <string name="desc_bloom_sprite_passionflower">Wijące się pnącza otwierają nad ziarnem ozdobny fioletowo-biały kwiat męczennicy.</string>
    <string name="label_bloom_sprite_bee_orchid">Dwulistnik pszczeli</string>
    <string name="desc_bloom_sprite_bee_orchid">Różowe płatki orchidei odsłaniają ciemne, pszczołokształtne warżki na smukłych łodygach.</string>
    <string name="label_bloom_sprite_jade_vine">Jadeitowe pnącze</string>
    <string name="desc_bloom_sprite_jade_vine">Pnącze wypuszcza z ziarna zwisające turkusowe grona kwiatów jadeitowych.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Strelicja królewska</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Pomarańczowe i głęboko niebieskie płatki strelicji rozwijają się z wyprostowanych zielonych liści.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Niebieski mak himalajski</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Zwieszony pąk otwiera się w błękitny mak ze złotymi pręcikami.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Czerwony, nakrapiany pasożytniczy kwiat pęcznieje w ogromny pięciopłatkowy rozkwit.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Kosmos czekoladowy</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">Pierzaste liście unoszą z ziarna aksamitne, ciemnobordowe kwiaty kosmosu.</string>
    <string name="label_bloom_sprite_flame_lily">Glorioza</string>
    <string name="desc_bloom_sprite_flame_lily">Zwijające się płomienne płatki lilii wyrastają na zielonych, wąsatych łodygach.</string>
    <string name="label_bloom_sprite_queen_of_the_night">Królowa Nocy</string>
    <string name="desc_bloom_sprite_queen_of_the_night">Łodyga kaktusa otwiera się w dramatyczny, warstwowy biały kwiat kwitnący nocą.</string>
    <string name="label_bloom_sprite_snowdrop">Przebiśnieg</string>
    <string name="desc_bloom_sprite_snowdrop">Delikatne białe dzwonki przebiśniegu wyrastają z pękniętego ziarna.</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
    <string name="desc_bloom_sprite_myosotis_sylvatica">Maleńkie niebieskie kwiaty niezapominajki z żółtymi środkami rozwijają się z ziarna.</string>
    <string name="label_bloom_sprite_fantasy_citadel">Fantastyczna cytadela</string>
    <string name="desc_bloom_sprite_fantasy_citadel">Pęknięte ziarno otwiera się w maleńką kamienną cytadelę z ciepłymi oknami.</string>
    <string name="label_bloom_sprite_cyber_city_vines">Pnącza cybermiasta</string>
    <string name="desc_bloom_sprite_cyber_city_vines">Neonowe pnącza obwodów wyrastają w kompaktowe miniaturowe cybermiasto.</string>
    <string name="label_bloom_sprite_pixel_micro_world">Pikselowy mikroświat</string>
    <string name="desc_bloom_sprite_pixel_micro_world">Ziarno rozpikselowuje się w maleńki retro mikroświat z bloków i terenu.</string>
    <string name="label_bloom_sprite_tabletop_adventure_map">Planszowa mapa przygody</string>
    <string name="desc_bloom_sprite_tabletop_adventure_map">Toczące się ziarno rozwija maleńką pergaminową mapę przygody i pustą klejnotową kość.</string>
    <string name="label_bloom_sprite_alchemy_astrolabe">Alchemiczne astrolabium</string>
    <string name="desc_bloom_sprite_alchemy_astrolabe">Mosiężne pierścienie i orbitujące szklane fiolki rozwijają się z ziarna kawy.</string>
    <string name="label_bloom_sprite_espresso_robot">Robot espresso</string>
    <string name="desc_bloom_sprite_espresso_robot">Ziarno rozwija się w maleńkiego mosiężnego robota napędzanego espresso.</string>
    <string name="label_bloom_sprite_space_habitat_ring">Pierścień kosmicznego habitatu</string>
    <string name="desc_bloom_sprite_space_habitat_ring">Zakrzywione fragmenty skorupki rozdzielają się w miniaturowy obracający się pierścień habitatu.</string>
    <string name="label_bloom_sprite_nerd_library_nook">Kącik biblioteczny geeka</string>
    <string name="desc_bloom_sprite_nerd_library_nook">Z ziarna wyskakuje biblioteczny kącik z półkami, lampą i kubkiem.</string>
    <string name="label_bloom_sprite_arcade_platformer_level">Poziom arcade platformówki</string>
    <string name="desc_bloom_sprite_arcade_platformer_level">Ziarno wypuszcza maleńki oryginalny poziom platformowy z blokami, klejnotami i flagą.</string>
    <string name="label_bloom_sprite_clockwork_dragonfly">Mechaniczna ważka</string>
    <string name="desc_bloom_sprite_clockwork_dragonfly">Kawowa skorupka wykluwa się w mosiężną nakręcaną ważkę.</string>
    <string name="label_bloom_sprite_observatory_dome">Kopuła obserwatorium</string>
    <string name="desc_bloom_sprite_observatory_dome">Ziarno otwiera się jak maleńka kopuła obserwatorium z mosiężnym teleskopem.</string>
    <string name="label_bloom_sprite_cyber_alchemy_engine">Silnik cyberalchemiczny</string>
    <string name="desc_bloom_sprite_cyber_alchemy_engine">Mosiężne pierścienie, obwody i bursztynowy rdzeń tworzą kompaktowy silnik cyberalchemiczny.</string>
    <string name="label_bloom_sprite_tabletop_space_colony">Planszowa kolonia kosmiczna</string>
    <string name="desc_bloom_sprite_tabletop_space_colony">Maleńka planszowa kolonia kosmiczna wyrasta z kopułami i pustymi księżycami z kości.</string>
    <string name="label_bloom_sprite_observatory_library">Biblioteka w obserwatorium</string>
    <string name="desc_bloom_sprite_observatory_library">Przytulna biblioteka w obserwatorium otwiera się z półkami, teleskopem i parowymi konstelacjami.</string>

