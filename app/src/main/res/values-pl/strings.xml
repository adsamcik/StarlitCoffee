    <string name="prep_tip_label">Przygotowanie</string>
    <string name="label_recipe_heading">Przepis</string>
    <string name="label_set_grinder_to">Ustaw młynek na</string>
    <string name="label_temp_short">Temp.</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Zwilż papierowy filtr w podstawie (zawór otwarty) i pozwól wodzie spłynąć. Zamontuj cylinder, wsyp kawę, wyrównaj złoże, załóż pokrywkę dyspersyjną. Wytaruj wagę.</string>
    <string name="prep_tip_pulsar_19k">Przepłucz metalowy filtr 19K, aby dobrze osiadł i rozgrzał cylinder. Zamontuj cylinder, wsyp kawę, wyrównaj złoże, załóż pokrywkę dyspersyjną. Wytaruj wagę.</string>
    <string name="prep_tip_pulsar_40k">Przepłucz metalowy filtr 40K, aby rozgrzać cylinder. Zamontuj cylinder, wsyp kawę, wyrównaj złoże, załóż pokrywkę dyspersyjną. Wytaruj wagę.</string>
    <string name="prep_tip_pour_over_paper">Załóż papierowy filtr i przepłucz go gorącą wodą, aby rozgrzać dripper i usunąć papierowy posmak. Wsyp kawę, wytaruj wagę.</string>
    <string name="prep_tip_french_press">Rozgrzej French Press, potem wylej wodę. Wsyp kawę, postaw na wadze i wytaruj przed dodaniem wody.</string>
    <string name="prep_tip_aeropress">Włóż przepłukany filtr do sitka. Wsyp kawę, postaw AeroPress na stabilnym kubku lub serwerze i wytaruj wagę.</string>
    <string name="prep_tip_espresso">Wytrzyj kolbę do sucha. Odmierz dawkę, rozprowadź ją równo i ubij poziomo przed zapięciem.</string>
    <string name="prep_tip_moka">Napełnij dolną komorę do zaworu. Wsyp kawę do sitka, wyrównaj — nie ubijaj. Ostrożnie skręć kawiarkę.</string>
    <string name="prep_tip_cold_brew">Wsyp kawę do naczynia, wytaruj wagę, dodaj zimną wodę lub wodę w temperaturze pokojowej i przykryj.</string>

