    <string name="prep_tip_label">Príprava</string>
    <string name="label_recipe_heading">Recept</string>
    <string name="label_set_grinder_to">Nastavte mlynček na</string>
    <string name="label_temp_short">Teplota</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Navlhčite papierový filter v základni (ventil otvorený) a nechajte odtiecť. Nasaďte valec, pridajte kávu, zarovnajte lôžko a položte disperzný kryt. Vytárujte váhu.</string>
    <string name="prep_tip_pulsar_19k">Prepláchnite kovový filter 19K, aby dobre dosadol, a predhrejte valec. Nasaďte valec, pridajte kávu, zarovnajte lôžko a položte disperzný kryt. Vytárujte váhu.</string>
    <string name="prep_tip_pulsar_40k">Prepláchnite kovový filter 40K, aby sa predhrial valec. Nasaďte valec, pridajte kávu, zarovnajte lôžko a položte disperzný kryt. Vytárujte váhu.</string>
    <string name="prep_tip_pour_over_paper">Vložte papierový filter a prepláchnite horúcou vodou, aby sa predhrial a odstránila sa papierová chuť. Pridajte kávu a vytárujte váhu.</string>
    <string name="prep_tip_french_press">Predhrejte French Press a potom ho vyprázdnite. Pridajte kávu, položte na váhu a pred pridaním vody vytárujte.</string>
    <string name="prep_tip_aeropress">Vložte prepláchnutý filter do viečka. Pridajte kávu, postavte AeroPress na pevnú šálku alebo server a vytárujte váhu.</string>
    <string name="prep_tip_espresso">Utrite páku dosucha. Nadávkujte, rovnomerne rozprestrite a utlačte do roviny pred nasadením.</string>
    <string name="prep_tip_moka">Naplňte spodnú komoru po ventil. Naplňte košík kávou, zarovnajte — neutláčajte. Opatrne zložte.</string>
    <string name="prep_tip_cold_brew">Nasypte kávu do nádoby, vytárujte váhu, potom pridajte vodu izbovej teploty alebo studenú vodu a zakryte.</string>

