    <string name="label_bloom_sprite_coffee_starlit">Café estrellado</string>
    <string name="desc_bloom_sprite_coffee_starlit">Pétalos de vapor crema-dorado con pequeños destellos estrellados.</string>
    <string name="label_bloom_sprite_coffee_latte">Bloom latte</string>
    <string name="desc_bloom_sprite_coffee_latte">Rosetta suave de latte art en tonos cálidos de espuma de leche.</string>
    <string name="label_bloom_sprite_coffee_plant">Planta de café</string>
    <string name="desc_bloom_sprite_coffee_plant">Plántula verde fresca de cafeto con hojas en pares.</string>
    <string name="label_bloom_sprite_cherry_tomato">Tomate cherry</string>
    <string name="desc_bloom_sprite_cherry_tomato">Un grano de café brota en una tomatera mientras maduran frutos rojos.</string>
    <string name="label_bloom_sprite_strawberry">Fresa</string>
    <string name="desc_bloom_sprite_strawberry">Un grano de café brota en una planta de fresa con flores y frutos rojos.</string>
    <string name="label_bloom_sprite_raspberry">Frambuesa</string>
    <string name="desc_bloom_sprite_raspberry">Un grano de café hace crecer zarzas con flores pálidas y racimos de frambuesas rojas.</string>
    <string name="label_bloom_sprite_blueberry">Arándano</string>
    <string name="desc_bloom_sprite_blueberry">Un grano de café hace crecer una ramita de arándano con flores acampanadas y frutos azules.</string>
    <string name="label_bloom_sprite_blackberry">Mora</string>
    <string name="desc_bloom_sprite_blackberry">Un grano de café hace crecer zarzas espinosas con racimos de moras oscuras.</string>
    <string name="label_bloom_sprite_coffee_brew">Preparación de café</string>
    <string name="desc_bloom_sprite_coffee_brew">Brillo ámbar de café con rizos de vapor crema.</string>
    <string name="label_bloom_sprite_rose">Rosa</string>
    <string name="desc_bloom_sprite_rose">Rosa roja compacta desplegándose sobre el grano.</string>
    <string name="label_bloom_sprite_lotus">Loto</string>
    <string name="desc_bloom_sprite_lotus">Flor de loto color crema con pétalos ahuecados en capas.</string>
    <string name="label_bloom_sprite_sunflower">Girasol</string>
    <string name="desc_bloom_sprite_sunflower">Girasol brillante con pétalos dorados y centro oscuro.</string>
    <string name="label_bloom_sprite_orchid">Orquídea</string>
    <string name="desc_bloom_sprite_orchid">Delicada orquídea blanca con lóbulos redondeados.</string>
    <string name="label_bloom_sprite_jasmine">Jazmín</string>
    <string name="desc_bloom_sprite_jasmine">Suave flor de jazmín blanca con forma ligera de molinillo.</string>
    <string name="label_bloom_sprite_bleeding_heart">Corazón sangrante</string>
    <string name="desc_bloom_sprite_bleeding_heart">Tallos arqueados con flores rosas en forma de corazón y puntas blancas como lágrimas se alzan desde el grano.</string>
    <string name="label_bloom_sprite_passionflower">Flor de la pasión</string>
    <string name="desc_bloom_sprite_passionflower">Enredaderas rizadas se abren en una flor de la pasión morada y blanca, ornamental, sobre el grano.</string>
    <string name="label_bloom_sprite_bee_orchid">Orquídea abeja</string>
    <string name="desc_bloom_sprite_bee_orchid">Pétalos rosas de orquídea revelan labios oscuros con forma de abeja en tallos delgados.</string>
    <string name="label_bloom_sprite_jade_vine">Enredadera de jade</string>
    <string name="desc_bloom_sprite_jade_vine">Una enredadera trepadora cuelga racimos turquesa de flores de jade desde el grano.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Ave del paraíso</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Pétalos naranjas y azul profundo de Strelitzia se despliegan desde hojas verdes erguidas.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Amapola azul del Himalaya</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Un capullo inclinado se abre en una amapola azul cielo con estambres dorados.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Una flor parasitaria roja y moteada se hincha hasta convertirse en una enorme flor de cinco lóbulos.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Cosmos chocolate</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">Hojas plumosas elevan flores de cosmos aterciopeladas, color borgoña oscuro, desde el grano.</string>
    <string name="label_bloom_sprite_flame_lily">Lirio de fuego</string>
    <string name="desc_bloom_sprite_flame_lily">Pétalos de lirio color llama se curvan hacia arriba sobre tallos verdes con zarcillos.</string>
    <string name="label_bloom_sprite_queen_of_the_night">Reina de la noche</string>
    <string name="desc_bloom_sprite_queen_of_the_night">Un tallo de cactus se abre en una dramática flor nocturna blanca en capas.</string>
    <string name="label_bloom_sprite_snowdrop">Campanilla de invierno</string>
    <string name="desc_bloom_sprite_snowdrop">Delicadas campanillas blancas se alzan desde el grano agrietado.</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
    <string name="desc_bloom_sprite_myosotis_sylvatica">Pequeñas flores azules de nomeolvides con centros amarillos se despliegan desde el grano.</string>

