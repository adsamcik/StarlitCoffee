    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="prep_tip_label">Preparación</string>
    <string name="label_recipe_heading">Receta</string>
    <string name="label_temp_short">Temp.</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Humedece el filtro de papel en la base (válvula abierta) y deja escurrir. Monta el cilindro, añade el café molido, nivela la cama y coloca la tapa de dispersión. Tara la báscula.</string>
    <string name="prep_tip_pulsar_19k">Enjuaga el filtro metálico 19K para asentarlo y precalentar el cilindro. Monta el cilindro, añade el café molido, nivela la cama y coloca la tapa de dispersión. Tara la báscula.</string>
    <string name="prep_tip_pulsar_40k">Enjuaga el filtro metálico 40K para precalentar el cilindro. Monta el cilindro, añade el café molido, nivela la cama y coloca la tapa de dispersión. Tara la báscula.</string>
    <string name="prep_tip_pour_over_paper">Coloca el filtro de papel y enjuágalo con agua caliente para precalentar y quitar el sabor a papel. Añade el café molido y tara la báscula.</string>
    <string name="prep_tip_french_press">Precalienta la prensa y vacíala. Añade el café molido, colócala en la báscula y tara antes de añadir agua.</string>
    <string name="prep_tip_aeropress">Inserta un filtro enjuagado en la tapa. Añade el café molido, coloca la cafetera sobre una taza resistente o una jarra y tara la báscula.</string>
    <string name="prep_tip_espresso">Seca el portafiltro. Dosifica, distribuye y compacta nivelado antes de encajarlo.</string>
    <string name="prep_tip_moka">Llena la cámara inferior hasta la válvula. Llena el cesto con café molido, nivela — no compactes. Ensambla con cuidado.</string>
    <string name="prep_tip_cold_brew">Añade el café molido al recipiente, tara la báscula, añade agua a temperatura ambiente o fría y tapa.</string>
    <string name="format_prep_grind_specific">Muele %1$s — ajusta %2$s a %3$s</string>
    <string name="format_prep_grind_generic">Muele %1$s — %2$s (%3$s)</string>

