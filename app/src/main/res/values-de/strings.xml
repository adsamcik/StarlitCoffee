    <string name="label_bloom_sprite_rose">Rose</string>
    <string name="desc_bloom_sprite_rose">Kompakte rote Rose, die sich über der Bohne entfaltet.</string>
    <string name="label_bloom_sprite_lotus">Lotus</string>
    <string name="desc_bloom_sprite_lotus">Cremefarbene Lotusblüte mit geschichteten, schalenförmigen Blütenblättern.</string>
    <string name="label_bloom_sprite_sunflower">Sonnenblume</string>
    <string name="desc_bloom_sprite_sunflower">Leuchtende Sonnenblume mit goldenen Blütenblättern und dunkler Mitte.</string>
    <string name="label_bloom_sprite_orchid">Orchidee</string>
    <string name="desc_bloom_sprite_orchid">Zarte weiße Orchidee mit gerundeten Lappen.</string>
    <string name="label_bloom_sprite_jasmine">Jasmin</string>
    <string name="desc_bloom_sprite_jasmine">Weiche weiße Jasminblüte mit sanfter Windradform.</string>
    <string name="label_bloom_sprite_bleeding_heart">Tränendes Herz</string>
    <string name="desc_bloom_sprite_bleeding_heart">Bogenförmige Stiele mit rosafarbenen herzförmigen Blüten und weißen Tropfenspitzen steigen aus der Bohne.</string>
    <string name="label_bloom_sprite_passionflower">Passionsblume</string>
    <string name="desc_bloom_sprite_passionflower">Rankende Triebe öffnen sich über der Bohne zu einer kunstvollen violett-weißen Passionsblume.</string>
    <string name="label_bloom_sprite_bee_orchid">Bienen-Ragwurz</string>
