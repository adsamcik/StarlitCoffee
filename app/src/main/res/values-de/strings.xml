    <string name="label_bloom_sprite_cherry_tomato">Kirschtomate</string>
    <string name="desc_bloom_sprite_cherry_tomato">Aus einer Kaffeebohne sprießt eine Tomatenranke, während rote Früchte reifen.</string>
