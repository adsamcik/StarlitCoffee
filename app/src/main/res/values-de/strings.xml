    <string name="label_bloom_sprite_raspberry">Himbeere</string>
    <string name="desc_bloom_sprite_raspberry">Aus einer Kaffeebohne wachsen Ranken mit hellen Blüten und roten Himbeertrauben.</string>
    <string name="label_bloom_sprite_blueberry">Blaubeere</string>
    <string name="desc_bloom_sprite_blueberry">Aus einer Kaffeebohne wächst ein Blaubeerzweig mit Glockenblüten und blauen Früchten.</string>
    <string name="label_bloom_sprite_blackberry">Brombeere</string>
