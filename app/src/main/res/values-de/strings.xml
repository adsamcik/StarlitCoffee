    <string name="label_bloom_sprite_jade_vine">Jadewein</string>
    <string name="desc_bloom_sprite_jade_vine">Eine Kletterranke hängt türkisfarbene Jade-Blütentrauben aus der Bohne.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Paradiesvogelblume</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Orangefarbene und tiefblaue Strelitzia-Blütenblätter entfalten sich aus aufrechten grünen Blättern.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Blauer Himalaya-Mohn</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Eine hängende Knospe öffnet sich zu einem himmelblauen Mohn mit goldenen Staubgefäßen.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Eine rot gefleckte parasitische Blüte schwillt zu einer riesigen fünflappigen Blume an.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Schokoladen-Kosmee</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">Feine Blätter heben samtig dunkelburgunderfarbene Kosmeenblüten aus der Bohne.</string>
    <string name="label_bloom_sprite_flame_lily">Ruhmeskrone</string>
    <string name="desc_bloom_sprite_flame_lily">Gedrehte flammenfarbene Lilienblätter steigen an rankenden grünen Stielen empor.</string>
    <string name="label_bloom_sprite_queen_of_the_night">Königin der Nacht</string>
