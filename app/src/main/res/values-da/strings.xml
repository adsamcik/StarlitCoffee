    <string name="label_bloom_sprite_blueberry">Blåbær</string>
    <string name="desc_bloom_sprite_blueberry">En kaffebønne vokser til en blåbærkvist med klokkeformede blomster og blå frugter.</string>
    <string name="label_bloom_sprite_blackberry">Brombær</string>
    <string name="desc_bloom_sprite_blackberry">En kaffebønne vokser til tornede ranker med mørke brombærklaser.</string>
    <string name="label_bloom_sprite_coffee_brew">Kaffebryg</string>
    <string name="desc_bloom_sprite_coffee_brew">Ravfarvet kaffeglød med cremede dampkrøller.</string>
    <string name="label_bloom_sprite_cursed_relic">Forbandet relikvie</string>
    <string name="desc_bloom_sprite_cursed_relic">En revnet bønne frigiver gylden magi og sort damp ind i en ulvelignende medaljon.</string>
    <string name="label_bloom_sprite_rose">Rose</string>
    <string name="desc_bloom_sprite_rose">Kompakt rød rose, der folder sig ud over bønnen.</string>
    <string name="label_bloom_sprite_lotus">Lotus</string>
    <string name="desc_bloom_sprite_lotus">Cremefarvet lotusblomst med lagdelte, skålformede kronblade.</string>
    <string name="label_bloom_sprite_sunflower">Solsikke</string>
    <string name="desc_bloom_sprite_sunflower">Klar solsikke med gyldne kronblade og mørk midte.</string>
    <string name="label_bloom_sprite_orchid">Orkidé</string>
    <string name="desc_bloom_sprite_orchid">Fin hvid orkidé med afrundede lapper.</string>
    <string name="label_bloom_sprite_jasmine">Jasmin</string>
    <string name="desc_bloom_sprite_jasmine">Blød hvid jasminblomst med en let vindmølleform.</string>
    <string name="label_bloom_sprite_bleeding_heart">Løjtnantshjerte</string>
