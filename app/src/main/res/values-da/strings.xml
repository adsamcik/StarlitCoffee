    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Fugt papirfilteret i bunden (ventil åben), og lad det dryppe af. Monter cylinderen, tilsæt kaffe, jævn bedet, og sæt dispersionslåget på. Tarér vægten.</string>
    <string name="prep_tip_pulsar_19k">Skyl 19K-metalfilteret, så det sætter sig, og forvarm cylinderen. Monter cylinderen, tilsæt kaffe, jævn bedet, og sæt dispersionslåget på. Tarér vægten.</string>
    <string name="prep_tip_pulsar_40k">Skyl 40K-metalfilteret for at forvarme cylinderen. Monter cylinderen, tilsæt kaffe, jævn bedet, og sæt dispersionslåget på. Tarér vægten.</string>
    <string name="prep_tip_pour_over_paper">Sæt papirfilteret i, og skyl med varmt vand for at forvarme og fjerne papirsmag. Tilsæt kaffe, og tarér vægten.</string>
    <string name="prep_tip_french_press">Forvarm stempelkanden, og tøm den. Tilsæt kaffe, sæt den på vægten, og tarér, før du tilsætter vand.</string>
    <string name="prep_tip_aeropress">Sæt et skyllet filter i låget. Tilsæt kaffe, stil bryggeren på et solidt krus eller en server, og tarér vægten.</string>
    <string name="prep_tip_espresso">Tør portafilteret af. Doser, fordel, og tamp plant, før du låser det i.</string>
    <string name="prep_tip_moka">Fyld bundkammeret op til ventilen. Fyld kurven med kaffe, jævn — tamp ikke. Saml forsigtigt.</string>
    <string name="prep_tip_cold_brew">Tilsæt kaffe i beholderen, tarér vægten, tilsæt vand ved stuetemperatur eller koldt vand, og dæk til.</string>

