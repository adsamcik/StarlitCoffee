    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">En rødplettet parasitisk bloom svulmer op til en enorm femlappet blomst.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Chokoladekosmos</string>
