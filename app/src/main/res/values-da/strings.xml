    <string name="label_bloom_sprite_tabletop_adventure_map">Bordrollespils-eventyrkort</string>
    <string name="desc_bloom_sprite_tabletop_adventure_map">En rullende bønne folder sig ud til et lille pergament-eventyrkort og en blank ædelstens-terning.</string>
    <string name="label_bloom_sprite_alchemy_astrolabe">Alkymi-astrolabium</string>
    <string name="desc_bloom_sprite_alchemy_astrolabe">Messingringe og kredsende glasflasker folder sig ud fra kaffebønnen.</string>
    <string name="label_bloom_sprite_espresso_robot">Espresso-robot</string>
    <string name="desc_bloom_sprite_espresso_robot">Bønnen folder sig ud til en lille espressodrevet messingrobot.</string>
    <string name="label_bloom_sprite_space_habitat_ring">Rumhabitat-ring</string>
    <string name="desc_bloom_sprite_space_habitat_ring">Buede skaldele deler sig til en miniature roterende habitat-ring.</string>
    <string name="label_bloom_sprite_nerd_library_nook">Nørdet bibliotekskrog</string>
    <string name="desc_bloom_sprite_nerd_library_nook">En pop op-bibliotekskrog åbner sig fra bønnen med hylder, lampe og krus.</string>
    <string name="label_bloom_sprite_arcade_platformer_level">Arkade-platformbane</string>
