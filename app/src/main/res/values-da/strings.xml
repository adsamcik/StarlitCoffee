    <string name="label_bloom_sprite_bee_orchid">Bi-orkidé</string>
    <string name="desc_bloom_sprite_bee_orchid">Lyserøde orkidéblade afslører mørke, bi-formede læber på slanke stængler.</string>
    <string name="label_bloom_sprite_jade_vine">Jaderanke</string>
    <string name="desc_bloom_sprite_jade_vine">En klatrende ranke hænger turkise jadeblomst-klaser fra bønnen.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Paradisfugl</string>
