    <string name="label_bloom_sprite_snowdrop">Vintergæk</string>
    <string name="desc_bloom_sprite_snowdrop">Fine hvide vintergæk-klokker rejser sig fra den revnede bønne.</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
