    <string name="label_bloom_sprite_raspberry">Zmeură</string>
    <string name="desc_bloom_sprite_raspberry">Un bob de cafea crește tufe de zmeur cu flori palide și ciorchini roșii.</string>
    <string name="label_bloom_sprite_blueberry">Afină</string>
