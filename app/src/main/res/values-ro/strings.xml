    <string name="label_bloom_sprite_jade_vine">Viță de jad</string>
    <string name="desc_bloom_sprite_jade_vine">O viță cățărătoare atârnă ciorchini turcoaz de flori de jad din bob.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Pasărea paradisului</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Petale portocalii și albastru intens de Strelitzia se desfac din frunze verzi verticale.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Mac albastru de Himalaya</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Un boboc aplecat se deschide într-un mac albastru ca cerul, cu stamine aurii.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Un bloom parazitic roșu, pătat, se umflă într-o floare uriașă cu cinci lobi.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Cosmos ciocolatiu</string>
