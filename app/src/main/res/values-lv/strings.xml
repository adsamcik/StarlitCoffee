    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="prep_tip_label">Sagatavošana</string>
    <string name="label_recipe_heading">Recepte</string>
    <string name="label_temp_short">Temp.</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Samitriniet papīra filtru pamatnē (vārsts atvērts) un noteciniet. Uzlieciet cilindru, pievienojiet malto kafiju, izlīdziniet slāni, uzlieciet dispersijas vāciņu. Nulējiet svarus.</string>
    <string name="prep_tip_pulsar_19k">Noskalojiet 19K metāla filtru, lai tas iegultos, un uzsildiet cilindru. Uzlieciet cilindru, pievienojiet malto kafiju, izlīdziniet slāni, uzlieciet dispersijas vāciņu. Nulējiet svarus.</string>
    <string name="prep_tip_pulsar_40k">Noskalojiet 40K metāla filtru, lai uzsildītu cilindru. Uzlieciet cilindru, pievienojiet malto kafiju, izlīdziniet slāni, uzlieciet dispersijas vāciņu. Nulējiet svarus.</string>
    <string name="prep_tip_pour_over_paper">Ievietojiet papīra filtru un izskalojiet ar karstu ūdeni, lai uzsildītu un noņemtu papīra garšu. Pievienojiet malto kafiju, nulējiet svarus.</string>
    <string name="prep_tip_french_press">Uzsildiet preskannu, tad izlejiet ūdeni. Pievienojiet malto kafiju, novietojiet uz svariem un nulējiet pirms ūdens pievienošanas.</string>
    <string name="prep_tip_aeropress">Ievietojiet noskalotu filtru vāciņā. Pievienojiet malto kafiju, novietojiet gatavotāju uz stabilas krūzes vai servēšanas trauka un nulējiet svarus.</string>
    <string name="prep_tip_espresso">Nosusiniet portafiltru. Ievietojiet devu, vienmērīgi sadaliet un līdzeni tampējiet pirms nostiprināšanas grupā.</string>
    <string name="prep_tip_moka">Piepildiet apakšējo kameru līdz vārstam. Piepildiet groziņu ar maltu kafiju, izlīdziniet — netampējiet. Salieciet uzmanīgi.</string>
    <string name="prep_tip_cold_brew">Pievienojiet malto kafiju traukā, nulējiet svarus, tad pievienojiet istabas temperatūras vai aukstu ūdeni un pārklājiet.</string>
