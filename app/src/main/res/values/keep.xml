<?xml version="1.0" encoding="utf-8"?>
<!--
    Preserves bloom "punk" theme drawables (PNG spritesheets + final stills)
    that are produced by the bloom-punk-image-generation and
    bloom-punk-prompt-workflow tooling but not yet wired into
    BloomSpritesheetOptions. They land in res/drawable-nodpi/ ahead of the
    code change that adds them to the picker so that artists can iterate on
    the spritesheets / prompts without their assets being lint-flagged or
    stripped by R8.

    Add new bloom_<theme>_final + bloom_<theme>_spritesheet pairs to the
    list below as new themes are generated.
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@drawable/bloom_aetherpunk_final
        ,@drawable/bloom_aetherpunk_spritesheet
        ,@drawable/bloom_bronzepunk_final
        ,@drawable/bloom_bronzepunk_spritesheet
        ,@drawable/bloom_clockpunk_final
        ,@drawable/bloom_clockpunk_spritesheet
        ,@drawable/bloom_cyberpunk_final
        ,@drawable/bloom_cyberpunk_spritesheet
        ,@drawable/bloom_desertpunk_final
        ,@drawable/bloom_desertpunk_spritesheet
        ,@drawable/bloom_dieselpunk_final
        ,@drawable/bloom_dieselpunk_spritesheet
        ,@drawable/bloom_ecopunk_final
        ,@drawable/bloom_ecopunk_spritesheet
        ,@drawable/bloom_frostpunk_final
        ,@drawable/bloom_frostpunk_spritesheet
        ,@drawable/bloom_gothic_punk_final
        ,@drawable/bloom_gothic_punk_spritesheet
        ,@drawable/bloom_nanopunk_final
        ,@drawable/bloom_nanopunk_spritesheet
        ,@drawable/bloom_oceanpunk_final
        ,@drawable/bloom_oceanpunk_spritesheet
        ,@drawable/bloom_piratepunk_final
        ,@drawable/bloom_piratepunk_spritesheet
        ,@drawable/bloom_silkpunk_final
        ,@drawable/bloom_silkpunk_spritesheet
        ,@drawable/bloom_solarpunk_final
        ,@drawable/bloom_solarpunk_spritesheet
        ,@drawable/bloom_steampunk_final
        ,@drawable/bloom_steampunk_spritesheet
        ,@drawable/bloom_weatherpunk_final
        ,@drawable/bloom_weatherpunk_spritesheet"
    tools:ignore="UnusedResources" />
