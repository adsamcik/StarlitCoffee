    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="prep_tip_label">Prep</string>
    <string name="prep_tip_pulsar_paper">Wet the paper filter in the base (valve open) and drain. Mount barrel, add grounds, level the bed, place dispersion cap. Tare scale.</string>
    <string name="prep_tip_pulsar_19k">Rinse the 19K metal filter to seat it and preheat the barrel. Mount barrel, add grounds, level the bed, place dispersion cap. Tare scale.</string>
    <string name="prep_tip_pulsar_40k">Rinse the 40K metal filter to preheat the barrel. Mount barrel, add grounds, level the bed, place dispersion cap. Tare scale.</string>
    <string name="prep_tip_pour_over_paper">Place the paper filter and rinse with hot water to preheat and remove papery taste. Add grounds, tare scale.</string>
    <string name="prep_tip_french_press">Preheat the press with hot water, then empty. Add grounds and tare scale.</string>
    <string name="prep_tip_aeropress">Insert a rinsed paper filter in the cap. Add grounds and tare scale.</string>
    <string name="prep_tip_espresso">Wipe the portafilter dry. Dose, level, and tamp evenly.</string>
    <string name="prep_tip_moka">Fill the bottom chamber with hot water to the valve. Fill the basket with grounds, level — don\'t tamp.</string>
    <string name="prep_tip_cold_brew">Add grounds to the vessel and tare scale.</string>

