<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup & device-transfer rules.

  Strategy:
    - cloud-backup (Google Drive Auto Backup, 25 MB/app cap, E2E encrypted on Android 9+):
        Keep the brew database and user preferences so settings/brew history survive
        a reinstall. Exclude bag photos (large JPEGs that blow the quota and may
        incidentally capture surroundings) and scan-session telemetry (diagnostic
        data not meaningful to restore).
    - device-transfer (D2D when moving to a new device, no quota):
        Keep the same exclusions for scan telemetry and bag photos; the database
        and preferences carry the user's actual data and that's what we want
        to migrate. (Photos can be re-imported on the new device.)
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="bag_photos/" />
        <exclude domain="sharedpref" path="scan_session_history.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="bag_photos/" />
        <exclude domain="sharedpref" path="scan_session_history.xml" />
    </device-transfer>
</data-extraction-rules>
