<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy Auto Backup rules for API 26-30 (devices running Android 8.0-11).
  Mirrors the cloud-backup section of data_extraction_rules.xml.

  See data_extraction_rules.xml for the modern (API 31+) equivalent and the
  rationale behind each exclusion.
-->
<full-backup-content>
    <include domain="database" path="starlit_coffee.db" />
    <include domain="database" path="starlit_coffee.db-journal" />
    <include domain="database" path="starlit_coffee.db-shm" />
    <include domain="database" path="starlit_coffee.db-wal" />
    <include domain="file" path="datastore/user_preferences.preferences_pb" />
</full-backup-content>
