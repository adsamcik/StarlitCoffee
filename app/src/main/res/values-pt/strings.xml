    <string name="label_bloom_sprite_coffee_flower">Flor do cafeeiro</string>
    <string name="desc_bloom_sprite_coffee_flower">Flor branca clássica do cafeeiro a abrir-se a partir do grão.</string>
    <string name="label_bloom_sprite_coffee_starlit">Café estrelado</string>
    <string name="desc_bloom_sprite_coffee_starlit">Pétalas de vapor creme-dourado com pequenos brilhos estrelados.</string>
    <string name="label_bloom_sprite_coffee_latte">Bloom latte</string>
    <string name="desc_bloom_sprite_coffee_latte">Roseta suave de latte art em tons quentes de espuma de leite.</string>
    <string name="label_bloom_sprite_coffee_plant">Cafeeiro</string>
    <string name="desc_bloom_sprite_coffee_plant">Rebento verde fresco de cafeeiro com folhas emparelhadas.</string>
    <string name="label_bloom_sprite_cherry_tomato">Tomate-cereja</string>
    <string name="desc_bloom_sprite_cherry_tomato">Um grão de café brota numa rama de tomateiro enquanto frutos vermelhos amadurecem.</string>
    <string name="label_bloom_sprite_strawberry">Morango</string>
    <string name="desc_bloom_sprite_strawberry">Um grão de café brota numa planta de morangueiro com flores e bagas vermelhas.</string>
    <string name="label_bloom_sprite_raspberry">Framboesa</string>
    <string name="desc_bloom_sprite_raspberry">Um grão de café faz crescer silvas com flores claras e cachos de framboesas vermelhas.</string>
    <string name="label_bloom_sprite_blueberry">Mirtilo</string>
    <string name="desc_bloom_sprite_blueberry">Um grão de café faz crescer um ramo de mirtilo com flores em sino e frutos azuis.</string>
    <string name="label_bloom_sprite_blackberry">Amora</string>
    <string name="desc_bloom_sprite_blackberry">Um grão de café faz crescer silvas espinhosas com cachos de amoras escuras.</string>
    <string name="label_bloom_sprite_coffee_brew">Café preparado</string>
    <string name="desc_bloom_sprite_coffee_brew">Brilho âmbar de café com espirais de vapor cremoso.</string>
    <string name="label_bloom_sprite_rose">Rosa</string>
    <string name="desc_bloom_sprite_rose">Rosa vermelha compacta a desabrochar sobre o grão.</string>
    <string name="label_bloom_sprite_lotus">Lótus</string>
    <string name="desc_bloom_sprite_lotus">Flor de lótus creme com pétalas sobrepostas em forma de taça.</string>
    <string name="label_bloom_sprite_sunflower">Girassol</string>
    <string name="desc_bloom_sprite_sunflower">Girassol luminoso com pétalas douradas e centro escuro.</string>
    <string name="label_bloom_sprite_orchid">Orquídea</string>
    <string name="desc_bloom_sprite_orchid">Delicada orquídea branca com lóbulos arredondados.</string>
    <string name="label_bloom_sprite_jasmine">Jasmim</string>
    <string name="desc_bloom_sprite_jasmine">Bloom suave de jasmim branco com forma delicada de cata-vento.</string>
    <string name="label_bloom_sprite_bleeding_heart">Coração-de-Maria</string>
    <string name="desc_bloom_sprite_bleeding_heart">Caules arqueados com flores cor-de-rosa em forma de coração e pontas brancas em gota sobem do grão.</string>
    <string name="label_bloom_sprite_passionflower">Flor-da-paixão</string>
    <string name="desc_bloom_sprite_passionflower">Trepadeiras encaracoladas abrem uma flor-da-paixão roxa e branca ornamentada acima do grão.</string>
    <string name="label_bloom_sprite_bee_orchid">Orquídea-abelha</string>
    <string name="desc_bloom_sprite_bee_orchid">Pétalas de orquídea cor-de-rosa revelam lábios escuros em forma de abelha sobre caules finos.</string>
    <string name="label_bloom_sprite_jade_vine">Trepadeira-jade</string>
    <string name="desc_bloom_sprite_jade_vine">Uma trepadeira suspende cachos de flores jade turquesa a partir do grão.</string>
    <string name="label_bloom_sprite_bird_of_paradise">Ave-do-paraíso</string>
    <string name="desc_bloom_sprite_bird_of_paradise">Pétalas laranja e azul-escuro de Strelitzia desdobram-se a partir de folhas verdes eretas.</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">Papoila-azul-do-Himalaia</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">Um botão pendente abre-se numa papoila azul-céu com estames dourados.</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">Um bloom parasita vermelho malhado incha até se tornar uma enorme flor de cinco lóbulos.</string>
    <string name="label_bloom_sprite_chocolate_cosmos">Cosmos-chocolate</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">Folhas finas erguem flores de cosmos aveludadas, cor de vinho escuro, a partir do grão.</string>
    <string name="label_bloom_sprite_flame_lily">Lírio-de-fogo</string>
    <string name="desc_bloom_sprite_flame_lily">Pétalas de lírio em tons de chama erguem-se em caules verdes com gavinhas.</string>
    <string name="label_bloom_sprite_queen_of_the_night">Dama-da-noite</string>
    <string name="desc_bloom_sprite_queen_of_the_night">Um caule de cato abre-se numa flor noturna branca, dramática e em camadas.</string>
    <string name="label_bloom_sprite_snowdrop">Campainha-branca</string>
    <string name="desc_bloom_sprite_snowdrop">Delicados sinos brancos de campainha-branca erguem-se do grão rachado.</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
    <string name="desc_bloom_sprite_myosotis_sylvatica">Minúsculas flores azuis de não-me-esqueças com centros amarelos desabrocham a partir do grão.</string>

