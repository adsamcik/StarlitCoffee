    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="prep_tip_label">Preparação</string>
    <string name="label_recipe_heading">Receita</string>
    <string name="label_temp_short">Temp.</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Molhe o filtro de papel na base (válvula aberta) e deixe escorrer. Monte o cilindro, adicione o café moído, nivele a cama e coloque a tampa de dispersão. Tare a balança.</string>
    <string name="prep_tip_pulsar_19k">Passe o filtro metálico 19K por água para o assentar e pré-aqueça o cilindro. Monte o cilindro, adicione o café moído, nivele a cama e coloque a tampa de dispersão. Tare a balança.</string>
    <string name="prep_tip_pulsar_40k">Passe o filtro metálico 40K por água para pré-aquecer o cilindro. Monte o cilindro, adicione o café moído, nivele a cama e coloque a tampa de dispersão. Tare a balança.</string>
    <string name="prep_tip_pour_over_paper">Coloque o filtro de papel e passe-o por água quente para pré-aquecer e remover o sabor a papel. Adicione o café moído e tare a balança.</string>
    <string name="prep_tip_french_press">Pré-aqueça a prensa, depois esvazie-a. Adicione o café moído, coloque na balança e tare antes de adicionar água.</string>
    <string name="prep_tip_aeropress">Insira um filtro enxaguado na tampa. Adicione o café moído, coloque o preparador sobre uma chávena ou jarro estável e tare a balança.</string>
    <string name="prep_tip_espresso">Seque o porta-filtro. Doseie, distribua e compacte nivelado antes de encaixar.</string>
    <string name="prep_tip_moka">Encha a câmara inferior até à válvula. Encha o cesto com café moído, nivele — não compacte. Monte com cuidado.</string>
    <string name="prep_tip_cold_brew">Adicione o café moído ao recipiente, tare a balança, depois adicione água à temperatura ambiente ou fria e tape.</string>
