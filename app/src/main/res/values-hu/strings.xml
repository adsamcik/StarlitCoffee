    <!-- Prep screen: single concise method + filter specific tip -->
    <string name="action_ready_to_brew_short">Kész a főzésre</string>
    <string name="prep_tip_label">Előkészítés</string>
    <string name="label_recipe_heading">Recept</string>
    <string name="label_temp_short">Hőm.</string>
    <string name="label_bloom_short">Bloom</string>
    <string name="prep_tip_pulsar_paper">Nedvesítse be a papírszűrőt az alaptestben (nyitott szeleppel), majd engedje le. Helyezze fel a hengert, adja hozzá az őrleményt, egyengesse el a kávéágyat, tegye fel az elosztósapkát. Nullázza a mérleget.</string>
    <string name="prep_tip_pulsar_19k">Öblítse át a 19K fémszűrőt, hogy a helyére üljön és előmelegítse a hengert. Helyezze fel a hengert, adja hozzá az őrleményt, egyengesse el a kávéágyat, tegye fel az elosztósapkát. Nullázza a mérleget.</string>
    <string name="prep_tip_pulsar_40k">Öblítse át a 40K fémszűrőt a henger előmelegítéséhez. Helyezze fel a hengert, adja hozzá az őrleményt, egyengesse el a kávéágyat, tegye fel az elosztósapkát. Nullázza a mérleget.</string>
    <string name="prep_tip_pour_over_paper">Helyezze be a papírszűrőt, és öblítse át forró vízzel az előmelegítéshez és a papírízek eltávolításához. Adja hozzá az őrleményt, nullázza a mérleget.</string>
    <string name="prep_tip_french_press">Melegítse elő a French presst, majd öntse ki. Adja hozzá az őrleményt, tegye a mérlegre, és nullázza a víz hozzáadása előtt.</string>
    <string name="prep_tip_aeropress">Tegyen egy átöblített szűrőt a kupakba. Adja hozzá az őrleményt, helyezze a készüléket egy stabil bögrére vagy kancsóra, és nullázza a mérleget.</string>
    <string name="prep_tip_espresso">Törölje szárazra a szűrőkart. Adagolja be, ossza el egyenletesen, és tömörítse laposra a rögzítés előtt.</string>
    <string name="prep_tip_moka">Töltse fel az alsó kamrát a szelepig. Töltse meg a kosarat őrleménnyel, egyengesse el — ne tömörítse. Óvatosan szerelje össze.</string>
    <string name="prep_tip_cold_brew">Adja az őrleményt az edénybe, nullázza a mérleget, majd öntsön hozzá szobahőmérsékletű vagy hideg vizet, és fedje le.</string>
