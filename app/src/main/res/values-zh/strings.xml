    <string name="label_bloom_sprite_coffee_flower">咖啡花</string>
    <string name="desc_bloom_sprite_coffee_flower">经典白色咖啡花从咖啡豆中绽放。</string>
    <string name="label_bloom_sprite_coffee_starlit">星光咖啡</string>
    <string name="desc_bloom_sprite_coffee_starlit">奶油金色蒸汽花瓣，带有细小星光高光。</string>
    <string name="label_bloom_sprite_coffee_latte">拿铁闷蒸</string>
    <string name="desc_bloom_sprite_coffee_latte">温暖奶泡色调中的柔和拉花玫瑰图案。</string>
    <string name="label_bloom_sprite_coffee_plant">咖啡树苗</string>
    <string name="desc_bloom_sprite_coffee_plant">清新的绿色咖啡幼苗，长着成对叶片。</string>
    <string name="label_bloom_sprite_cherry_tomato">樱桃番茄</string>
    <string name="desc_bloom_sprite_cherry_tomato">咖啡豆发芽成番茄藤，红色果实逐渐成熟。</string>
    <string name="label_bloom_sprite_strawberry">草莓</string>
    <string name="desc_bloom_sprite_strawberry">咖啡豆发芽成草莓植株，开花并结出红莓。</string>
    <string name="label_bloom_sprite_raspberry">覆盆子</string>
    <string name="desc_bloom_sprite_raspberry">咖啡豆长出带浅色花朵和红色覆盆子果簇的藤蔓。</string>
    <string name="label_bloom_sprite_blueberry">蓝莓</string>
    <string name="desc_bloom_sprite_blueberry">咖啡豆长出蓝莓小枝，带铃形花和蓝色果实。</string>
    <string name="label_bloom_sprite_blackberry">黑莓</string>
    <string name="desc_bloom_sprite_blackberry">咖啡豆长出带刺藤蔓和深色黑莓果簇。</string>
    <string name="label_bloom_sprite_coffee_brew">咖啡冲煮</string>
    <string name="desc_bloom_sprite_coffee_brew">琥珀色咖啡光泽与奶油色蒸汽卷。</string>
    <string name="label_bloom_sprite_rose">玫瑰</string>
    <string name="desc_bloom_sprite_rose">紧凑的红玫瑰在咖啡豆上方展开。</string>
    <string name="label_bloom_sprite_lotus">莲花</string>
    <string name="desc_bloom_sprite_lotus">奶油色莲花，层叠杯状花瓣。</string>
    <string name="label_bloom_sprite_sunflower">向日葵</string>
    <string name="desc_bloom_sprite_sunflower">明亮向日葵，金色花瓣与深色花心。</string>
    <string name="label_bloom_sprite_orchid">兰花</string>
    <string name="desc_bloom_sprite_orchid">精致白色兰花，花瓣圆润。</string>
    <string name="label_bloom_sprite_jasmine">茉莉</string>
    <string name="desc_bloom_sprite_jasmine">柔白茉莉花，带轻柔的风车形。</string>
    <string name="label_bloom_sprite_bleeding_heart">荷包牡丹</string>
    <string name="desc_bloom_sprite_bleeding_heart">弧形茎秆从咖啡豆中升起，挂着粉色心形花和白色泪滴尖端。</string>
    <string name="label_bloom_sprite_passionflower">西番莲</string>
    <string name="desc_bloom_sprite_passionflower">卷曲藤蔓在咖啡豆上方绽开华丽的紫白色西番莲。</string>
    <string name="label_bloom_sprite_bee_orchid">蜂兰</string>
    <string name="desc_bloom_sprite_bee_orchid">粉色兰花花瓣露出深色、像蜜蜂的唇瓣，立在细茎上。</string>
    <string name="label_bloom_sprite_jade_vine">翡翠葛</string>
    <string name="desc_bloom_sprite_jade_vine">攀援藤蔓从咖啡豆上垂下绿松石色翡翠花簇。</string>
    <string name="label_bloom_sprite_bird_of_paradise">天堂鸟</string>
    <string name="desc_bloom_sprite_bird_of_paradise">橙色与深蓝色Strelitzia花瓣从直立绿叶中展开。</string>
    <string name="label_bloom_sprite_blue_himalayan_poppy">蓝色喜马拉雅罂粟</string>
    <string name="desc_bloom_sprite_blue_himalayan_poppy">低垂花苞张开成天蓝色罂粟，带金色花蕊。</string>
    <string name="label_bloom_sprite_rafflesia">Rafflesia</string>
    <string name="desc_bloom_sprite_rafflesia">红色斑点寄生花膨胀成巨大的五裂花朵。</string>
    <string name="label_bloom_sprite_chocolate_cosmos">巧克力波斯菊</string>
    <string name="desc_bloom_sprite_chocolate_cosmos">羽状叶托起天鹅绒般深酒红色的波斯菊花。</string>
    <string name="label_bloom_sprite_flame_lily">火焰百合</string>
    <string name="desc_bloom_sprite_flame_lily">卷曲火焰色百合花瓣从带卷须的绿色茎上升起。</string>
    <string name="label_bloom_sprite_queen_of_the_night">夜之女王</string>
    <string name="desc_bloom_sprite_queen_of_the_night">仙人掌茎打开成层叠而戏剧性的白色夜开花。</string>
    <string name="label_bloom_sprite_snowdrop">雪滴花</string>
    <string name="desc_bloom_sprite_snowdrop">精致白色雪滴花铃从裂开的咖啡豆中升起。</string>
    <string name="label_bloom_sprite_myosotis_sylvatica">Myosotis sylvatica</string>
    <string name="desc_bloom_sprite_myosotis_sylvatica">小小的蓝色勿忘我花带黄色花心，从咖啡豆中展开。</string>

